<Window x:Class="ScreenshotOverlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FrameSnip"
        Width="420"
        Height="260"
        Left="120"
        Top="120"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="True">
  <Window.Resources>
    <SolidColorBrush x:Key="PanelFillBrush" Color="#E8141414" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#33FFFFFF" />
    <SolidColorBrush x:Key="PanelTextBrush" Color="#FFF6F6F6" />
    <SolidColorBrush x:Key="PanelSubtleTextBrush" Color="#C8FFFFFF" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FFD83A34" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="#24FFFFFF" />
    <Style x:Key="InvisibleThumbStyle"
           TargetType="{x:Type Thumb}">
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Background" Value="#01000000" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Thumb}">
            <Border Background="{TemplateBinding Background}" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="CircleButtonStyle"
           TargetType="{x:Type Button}">
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Background" Value="#F3F5F5F5" />
      <Setter Property="BorderBrush" Value="#33111111" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="#FF111111" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Grid>
              <Ellipse Fill="{TemplateBinding Background}"
                       Stroke="{TemplateBinding BorderBrush}"
                       StrokeThickness="{TemplateBinding BorderThickness}" />
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="MiniButtonStyle"
           TargetType="{x:Type Button}">
      <Setter Property="Width" Value="30" />
      <Setter Property="Height" Value="30" />
      <Setter Property="Margin" Value="0,0,5,0" />
      <Setter Property="Background" Value="{StaticResource PanelFillBrush}" />
      <Setter Property="Foreground" Value="{StaticResource PanelTextBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="9">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="BorderBrush" Value="#66FFFFFF" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="ColorSwatchButtonStyle"
           TargetType="{x:Type Button}">
      <Setter Property="Width" Value="22" />
      <Setter Property="Height" Value="22" />
      <Setter Property="Margin" Value="0,0,5,0" />
      <Setter Property="BorderBrush" Value="#80FFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="11" />
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="BadgeStyle"
           TargetType="{x:Type Border}">
      <Setter Property="Padding" Value="9,5" />
      <Setter Property="Background" Value="{StaticResource PanelFillBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
  </Window.Resources>

  <Grid>
    <Grid x:Name="FrameModeLayer">
      <Border x:Name="FrameBorder"
            Margin="18"
            BorderBrush="#FFFAFAFA"
            BorderThickness="1"
            CornerRadius="2"
            Background="Transparent"
            SnapsToDevicePixels="True" />
      <Border x:Name="VerticalSnapGuide"
              Width="1"
              Background="#66FFFFFF"
              Opacity="0"
              HorizontalAlignment="Left"
              VerticalAlignment="Stretch"
              Panel.ZIndex="2" />
      <Border x:Name="HorizontalSnapGuide"
              Height="1"
              Background="#66FFFFFF"
              Opacity="0"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Top"
              Panel.ZIndex="2" />

      <Grid Margin="32"
          IsHitTestVisible="False">
        <Border x:Name="SizeBadge"
              Style="{StaticResource BadgeStyle}"
              HorizontalAlignment="Right"
              VerticalAlignment="Bottom"
              Padding="8,4">
          <TextBlock x:Name="SizeLabel"
                   Foreground="{StaticResource PanelSubtleTextBrush}"
                   FontSize="10"
                   Text="0 x 0" />
        </Border>
      </Grid>

      <Border x:Name="StatusBadge"
            Style="{StaticResource BadgeStyle}"
            Width="64"
            HorizontalAlignment="Left"
            VerticalAlignment="Bottom"
            Margin="32,0,0,32"
            Padding="10,6"
            Panel.ZIndex="50"
            MouseEnter="StatusBadge_OnMouseEnter"
            MouseLeave="StatusBadge_OnMouseLeave"
            MouseLeftButtonDown="StatusBadge_OnMouseLeftButtonDown"
            MouseMove="StatusBadge_OnMouseMove"
            MouseLeftButtonUp="StatusBadge_OnMouseLeftButtonUp"
            LostMouseCapture="StatusBadge_OnLostMouseCapture">
        <StackPanel>
          <TextBlock x:Name="ModeLabel"
                   Foreground="{StaticResource PanelTextBrush}"
                   FontSize="11"
                   FontWeight="SemiBold"
                   Text="Active" />
          <TextBlock x:Name="HintLabel"
                   Foreground="{StaticResource PanelSubtleTextBrush}"
                   FontSize="10"
                   Margin="0,2,0,0"
                   TextWrapping="NoWrap"
                   Visibility="Collapsed"
                   Text="Ctrl+Shift+S to capture" />
        </StackPanel>
      </Border>

      <Button x:Name="CaptureButton"
            Style="{StaticResource CircleButtonStyle}"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Margin="0,40,40,0"
            Panel.ZIndex="60"
            Click="CaptureButton_OnClick"
            ToolTip="Capture to clipboard"
            Focusable="False">
      <Viewbox Width="12"
               Height="12">
        <Canvas Width="20"
                Height="20">
          <Rectangle Width="14"
                     Height="10"
                     RadiusX="2"
                     RadiusY="2"
                     Stroke="#FF111111"
                     StrokeThickness="1.6"
                     Fill="Transparent"
                     Canvas.Left="3"
                     Canvas.Top="6" />
          <Rectangle Width="5"
                     Height="3"
                     RadiusX="1"
                     RadiusY="1"
                     Fill="#FF111111"
                     Canvas.Left="6"
                     Canvas.Top="3" />
          <Ellipse Width="5"
                   Height="5"
                   Stroke="#FF111111"
                   StrokeThickness="1.4"
                   Fill="Transparent"
                   Canvas.Left="7.5"
                   Canvas.Top="8.5" />
          </Canvas>
        </Viewbox>
      </Button>

      <Button x:Name="SelectionCaptureButton"
            Style="{StaticResource CircleButtonStyle}"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="40,40,0,0"
            Panel.ZIndex="60"
            Click="SelectionCaptureButton_OnClick"
            ToolTip="Drag a new capture region"
            Focusable="False">
      <Viewbox Width="12"
               Height="12">
        <Canvas Width="20"
                Height="20">
          <Path Stroke="#FF111111"
                StrokeThickness="1.6"
                StrokeStartLineCap="Round"
                StrokeEndLineCap="Round"
                Data="M7,3 H3 V7 M13,3 H17 V7 M7,17 H3 V13 M13,17 H17 V13" />
        </Canvas>
      </Viewbox>
      </Button>

      <Thumb x:Name="MoveThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Margin="48"
            Cursor="SizeAll"
            DragDelta="MoveThumb_OnDragDelta" />

      <Thumb x:Name="LeftThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Width="36"
           HorizontalAlignment="Left"
           Panel.ZIndex="30"
           Cursor="SizeWE"
           DragDelta="LeftThumb_OnDragDelta" />
      <Thumb x:Name="RightThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Width="36"
           HorizontalAlignment="Right"
           Panel.ZIndex="30"
           Cursor="SizeWE"
           DragDelta="RightThumb_OnDragDelta" />
      <Thumb x:Name="TopThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Height="36"
           VerticalAlignment="Top"
           Panel.ZIndex="30"
           Cursor="SizeNS"
           DragDelta="TopThumb_OnDragDelta" />
      <Thumb x:Name="BottomThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Height="36"
           VerticalAlignment="Bottom"
           Panel.ZIndex="30"
           Cursor="SizeNS"
           DragDelta="BottomThumb_OnDragDelta" />

      <Thumb x:Name="TopLeftThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Width="56"
           Height="56"
           HorizontalAlignment="Left"
           VerticalAlignment="Top"
           Panel.ZIndex="31"
           Cursor="SizeNWSE"
           DragDelta="TopLeftThumb_OnDragDelta" />
      <Thumb x:Name="TopRightThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Width="56"
           Height="56"
           HorizontalAlignment="Right"
           VerticalAlignment="Top"
           Panel.ZIndex="31"
           Cursor="SizeNESW"
           DragDelta="TopRightThumb_OnDragDelta" />
      <Thumb x:Name="BottomLeftThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Width="56"
           Height="56"
           HorizontalAlignment="Left"
           VerticalAlignment="Bottom"
           Panel.ZIndex="31"
           Cursor="SizeNESW"
           DragDelta="BottomLeftThumb_OnDragDelta" />
      <Thumb x:Name="BottomRightThumb"
           Style="{StaticResource InvisibleThumbStyle}"
           Width="56"
           Height="56"
           HorizontalAlignment="Right"
           VerticalAlignment="Bottom"
           Panel.ZIndex="31"
           Cursor="SizeNWSE"
           DragDelta="BottomRightThumb_OnDragDelta" />
    </Grid>

    <Grid x:Name="AnnotationLayer"
          Visibility="Collapsed"
          Background="Transparent">
      <Grid.RowDefinitions>
        <RowDefinition Height="34" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid x:Name="AnnotationContentHost"
            Grid.Row="1"
            Margin="18,18,0,18"
            HorizontalAlignment="Left">
        <Border BorderBrush="#FFF5F5F5"
                BorderThickness="1"
                CornerRadius="2"
                Background="#F20A0A0A"
                SnapsToDevicePixels="True" />

        <Image x:Name="CapturedImage"
               Margin="1"
               Stretch="Fill"
               SnapsToDevicePixels="True" />

        <InkCanvas x:Name="AnnotationCanvas"
                   Margin="1"
                   Background="Transparent" />

        <Canvas x:Name="ShapeCanvas"
                Margin="1"
                Background="Transparent" />

      </Grid>

      <Border x:Name="AnnotationToolbarHost"
              Width="438"
              HorizontalAlignment="Left"
              VerticalAlignment="Top"
              Grid.RowSpan="2"
              Margin="18,20,0,0"
              Background="Transparent">
        <StackPanel Orientation="Horizontal">
        <Button x:Name="PenToolButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="PenToolButton_OnClick"
                ToolTip="Pen">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.8"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Data="M5,15 L8,18 L16,10 L13,7 Z" />
              <Path Stroke="White"
                    StrokeThickness="1.6"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    Data="M12.8,7.2 L15.8,4.2" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="EraserToolButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="EraserToolButton_OnClick"
                ToolTip="Eraser">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.7"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Data="M5,13 L9,17 L16,10 L12,6 Z" />
              <Path Stroke="White"
                    StrokeThickness="1.5"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    Data="M4,15 L9,20" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="RectangleToolButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="RectangleToolButton_OnClick"
                ToolTip="Rectangle">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Rectangle Width="12"
                         Height="9"
                         Stroke="White"
                         RadiusX="2"
                         RadiusY="2"
                         StrokeThickness="1.7"
                         Fill="Transparent"
                         Canvas.Left="4"
                         Canvas.Top="5" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="RedactToolButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="RedactToolButton_OnClick"
                ToolTip="Redact">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Rectangle Width="12"
                         Height="9"
                         RadiusX="2"
                         RadiusY="2"
                         Fill="White"
                         Canvas.Left="4"
                         Canvas.Top="5" />
              <Path Stroke="#AA141414"
                    StrokeThickness="1.2"
                    Data="M6,7 L14,13" />
            </Canvas>
          </Viewbox>
        </Button>
        <Border Width="1"
                Height="18"
                Margin="1,0,7,0"
                VerticalAlignment="Center"
                Background="{StaticResource SeparatorBrush}" />
        <Button x:Name="ColorMenuButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="ColorMenuButton_OnClick"
                ToolTip="Colors">
          <Grid>
            <Ellipse x:Name="ActiveColorDot"
                     Width="14"
                     Height="14"
                     Fill="#FFEF4444"
                     Stroke="White"
                     StrokeThickness="1" />
            <Path Stroke="White"
                  StrokeThickness="1"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"
                  Data="M20,9 L23,12 L26,9"
                  Stretch="Fill"
                  Width="6"
                  Height="4"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Bottom"
                  Margin="0,0,1,2" />
          </Grid>
        </Button>
        <Popup x:Name="ColorPopup"
               PlacementTarget="{Binding ElementName=ColorMenuButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
          <Border Background="#EE141414"
                  BorderBrush="{StaticResource PanelBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="12"
                  Padding="7">
            <StackPanel Orientation="Horizontal">
              <Button x:Name="RedColorButton"
                      Style="{StaticResource ColorSwatchButtonStyle}"
                      Background="#FFEF4444"
                      Click="RedColorButton_OnClick"
                      ToolTip="Red" />
              <Button x:Name="BlueColorButton"
                      Style="{StaticResource ColorSwatchButtonStyle}"
                      Background="#FF3B82F6"
                      Click="BlueColorButton_OnClick"
                      ToolTip="Blue" />
              <Button x:Name="GreenColorButton"
                      Style="{StaticResource ColorSwatchButtonStyle}"
                      Background="#FF22C55E"
                      Click="GreenColorButton_OnClick"
                      ToolTip="Green" />
              <Button x:Name="BlackColorButton"
                      Style="{StaticResource ColorSwatchButtonStyle}"
                      Background="#FF111111"
                      Click="BlackColorButton_OnClick"
                      ToolTip="Black" />
            </StackPanel>
          </Border>
        </Popup>
        <Border Width="1"
                Height="18"
                Margin="1,0,7,0"
                VerticalAlignment="Center"
                Background="{StaticResource SeparatorBrush}" />
        <Button x:Name="UndoAnnotationButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="UndoAnnotationButton_OnClick"
                ToolTip="Undo">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.8"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Data="M8,5 L4,10 L8,15" />
              <Path Stroke="White"
                    StrokeThickness="1.8"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Data="M5,10 L13,10 C15.5,10 16.5,8.5 16.5,6.5" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="RedoAnnotationButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="RedoAnnotationButton_OnClick"
                ToolTip="Redo">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.8"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Data="M12,5 L16,10 L12,15" />
              <Path Stroke="White"
                    StrokeThickness="1.8"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Data="M15,10 L7,10 C4.5,10 3.5,8.5 3.5,6.5" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="ClearAnnotationButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="ClearAnnotationButton_OnClick"
                ToolTip="Clear">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.9"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    Data="M6,6 L14,14 M14,6 L6,14" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="SaveAnnotationButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="SaveAnnotationButton_OnClick"
                ToolTip="Save PNG">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.6"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    Data="M5,5 L15,5 L15,15 L5,15 Z" />
              <Path Stroke="White"
                    StrokeThickness="1.6"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    Data="M7,5 L7,9 L13,9 L13,5 M8,14 L12,14" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="OcrAnnotationButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="OcrAnnotationButton_OnClick"
                ToolTip="OCR text">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.6"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    Data="M4,6 L16,6 M4,10 L12,10 M4,14 L10,14" />
              <Rectangle Width="6"
                         Height="10"
                         RadiusX="1.5"
                         RadiusY="1.5"
                         Stroke="White"
                         StrokeThickness="1.4"
                         Fill="Transparent"
                         Canvas.Left="11"
                         Canvas.Top="5" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="CopyAnnotationButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="CopyAnnotationButton_OnClick"
                ToolTip="Copy">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Rectangle Width="8"
                         Height="10"
                         RadiusX="1.5"
                         RadiusY="1.5"
                         Stroke="White"
                         StrokeThickness="1.5"
                         Fill="Transparent"
                         Canvas.Left="7"
                         Canvas.Top="6" />
              <Rectangle Width="8"
                         Height="10"
                         RadiusX="1.5"
                         RadiusY="1.5"
                         Stroke="White"
                         StrokeThickness="1.5"
                         Fill="Transparent"
                         Canvas.Left="4"
                         Canvas.Top="3" />
            </Canvas>
          </Viewbox>
        </Button>
        <Button x:Name="CloseAnnotationButton"
                Style="{StaticResource MiniButtonStyle}"
                Click="CloseAnnotationButton_OnClick"
                ToolTip="Back">
          <Viewbox Width="14"
                   Height="14">
            <Canvas Width="20"
                    Height="20">
              <Path Stroke="White"
                    StrokeThickness="1.9"
                    StrokeStartLineCap="Round"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    Data="M12,4.5 L6,10 L12,15.5" />
            </Canvas>
          </Viewbox>
        </Button>
        </StackPanel>
      </Border>
    </Grid>
  </Grid>
</Window>
